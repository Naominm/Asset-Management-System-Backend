// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  fullName     String
  staffNo      String        @unique
  jobTitle     String
  email        String        @unique
  password     String
  role         Role
  departmentId Int
  department   Department    @relation(fields: [departmentId], references: [id])
  activityLogs ActivityLog[]
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
}

model AccessRequest {
  id            Int    @id @default(autoincrement())
  fullName      String
  staffNo       String
  jobTitle      String
  email         String
  departmentId  Int
  roleRequested Role
  reason        String

  approved Boolean @default(false)

  createdAt DateTime @default(now())
}

model Department {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  Users           User[]
  assets          Asset[]
  assetAssignment AssetAssignment[]
}

model Asset {
  id                Int               @id @default(autoincrement())
  tagNo             String            @unique
  systemAssetId     String?           @unique
  category          String
  subCategory       String?
  assetDescription  String?
  make              String
  model             String
  physicalCondition String?
  serialNumber      String            @unique
  macAddress        String?
  imeiNumber        String?
  color             String?
  departmentId      Int
  department        Department        @relation(fields: [departmentId], references: [id])
  status            AssetStatus       @default(Available)
  hardwareSpec      HardwareSpec?
  procurement       Procurement?
  assignment        AssetAssignment[]
  activityLogs      ActivityLog[]
}

model HardwareSpec {
  id              Int     @id @default(autoincrement())
  assetId         Int     @unique
  asset           Asset   @relation(fields: [assetId], references: [id])
  processor       String?
  ram             String?
  storage         String?
  screenSize      String?
  powerRating     String?
  color           String?
  operatingSystem String?
  osVersion       String?
  ipAddress       String?
  hostName        String?
}

model Procurement {
  id               Int       @id @default(autoincrement())
  assetId          Int       @unique
  asset            Asset     @relation(fields: [assetId], references: [id])
  procurementDate  DateTime
  supplierVendor   String
  fundingSource    String?
  invoiceNumber    String?
  iopNumber        String?
  purchasePriceKES Float?
  warrantyStart    DateTime?
  warrantyEnd      DateTime?
  warrantyType     String?
  warrantyProvider String?
  warrantyContact  String?
}

model AssetAssignment {
  id             Int        @id @default(autoincrement())
  assetId        Int
  asset          Asset      @relation(fields: [assetId], references: [id])
  departmentId   Int
  department     Department @relation(fields: [departmentId], references: [id])
  assignedTo     String
  payRollNo      String
  floorLevel     String?
  roomNumber     String?
  accessories    String?
  notes          String?
  disposalDate   DateTime?
  disposalMethod String?
  assignedAt     DateTime   @default(now())
  returnedAt     DateTime?
}

model ActivityLog {
  id        Int          @id @default(autoincrement())
  type      ActivityType
  message   String
  assetId   Int?
  asset     Asset?       @relation(fields: [assetId], references: [id])
  userId    Int?
  user      User?        @relation(fields: [userId], references: [id])
  createdAt DateTime     @default(now())
}

enum ActivityType {
  REGISTRATION
  ASSIGNMENT
  MAINTENANCE
  TICKET_CREATED
  STATUS_CHANGE
}

enum Role {
  ICT_OFFICER
  ICT_ADMIN
}

enum AssetStatus {
  Available
  Assigned
  InStore
  Maintenance
}
