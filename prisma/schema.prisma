generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  fullName     String
  staffNo      String     @unique
  jobTitle     String
  email        String     @unique
  password     String
  role         Role
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
}

model AccessRequest {
  id            Int    @id @default(autoincrement())
  fullName      String
  staffNo       String
  jobTitle      String
  email         String
  departmentId  Int
  roleRequested Role
  reason        String

  approved Boolean @default(false)

  createdAt DateTime @default(now())
}

model Department {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  Users  User[]
  assets Asset[]
}

model Asset {
  id                Int         @id @default(autoincrement())
  tagNo             String      @unique
  systemAssetId     String?     @unique
  category          String
  subCategory       String?
  assetDescription  String?
  make              String
  model             String
  physicalCondition String?
  serialNumber      String      @unique
  macAddress        String?
  imeiNumber        String?
  color             String?
  departmentId      Int
  department        Department  @relation(fields: [departmentId], references: [id])
  status            AssetStatus @default(Available)
}

enum Role {
  ICT_OFFICER
  ICT_ADMIN
}

enum AssetStatus {
  Available
  Assigned
  InStore
  Maintenance
}
